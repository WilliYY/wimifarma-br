# App
APP_HOST_BIND="127.0.0.1"
APP_PORT="3001"
NEXTAUTH_URL="http://localhost:3001"
AUTH_URL="http://localhost:3001"
AUTH_SECRET="change-me-use-a-secure-random-value-with-at-least-32-chars"
NODE_OPTIONS="--max_old_space_size=1024"

# Docker memory budget
APP_MEM_LIMIT="1536m"
APP_MEM_RESERVATION="512m"
POSTGRES_MEM_LIMIT="768m"
POSTGRES_MEM_RESERVATION="512m"
POSTGRES_SHM_SIZE="128mb"
POSTGRES_SHARED_BUFFERS="256MB"
POSTGRES_WORK_MEM="8MB"
POSTGRES_MAINTENANCE_WORK_MEM="128MB"
POSTGRES_EFFECTIVE_CACHE_SIZE="768MB"
POSTGRES_MAX_CONNECTIONS="50"
TOOLS_MEM_LIMIT="768m"
TOOLS_MEM_RESERVATION="256m"

# PostgreSQL container
POSTGRES_DB="wimifarma_br"
POSTGRES_USER="wimifarma_user"
POSTGRES_PASSWORD="change-me-local-password"

# Internal Docker Compose database URL
DATABASE_URL="postgresql://wimifarma_user:change-me-local-password@postgres:5432/wimifarma_br?schema=public"

# Initial admin seed
ADMIN_NAME="Wimifarma Admin"
ADMIN_EMAIL="admin@wimifarma.local"
ADMIN_PASSWORD="change-me-admin-password"
ADMIN_RESET_PASSWORD="false"

# Optional Google login for future customer accounts
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
