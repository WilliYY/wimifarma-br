generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OfferStatus {
  DRAFT
  ACTIVE
  SCHEDULED
  EXPIRED
  ARCHIVED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum SpinWheelAttemptStatus {
  WON
  LOST
  BLOCKED
}

enum CashbackTransactionType {
  CREDIT
  DEBIT
  EXPIRE
  ADJUSTMENT
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(STAFF)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdOffers Offer[]   @relation("OfferCreator")
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([role])
  @@index([isActive])
}

model Product {
  id                 String        @id @default(cuid())
  name               String
  slug               String        @unique
  sku                String?       @unique
  ean                String?
  brand              String?
  category           String?
  description        String?
  price              Decimal       @db.Decimal(10, 2)
  promotionalPrice   Decimal?      @db.Decimal(10, 2)
  imageUrl           String?
  isPopularPharmacy  Boolean       @default(false)
  requiresPrescription Boolean     @default(false)
  status             ProductStatus @default(DRAFT)
  stock              Int           @default(0)
  sortOrder          Int           @default(0)
  offers             Offer[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([category])
  @@index([status])
  @@index([isPopularPharmacy])
}

model Offer {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  description    String?
  productId      String?
  product        Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  originalPrice  Decimal?    @db.Decimal(10, 2)
  offerPrice     Decimal     @db.Decimal(10, 2)
  startsAt       DateTime?
  endsAt         DateTime?
  status         OfferStatus @default(DRAFT)
  imageUrl       String?
  highlight      Boolean     @default(false)
  whatsappText   String?
  createdById    String?
  createdBy      User?       @relation("OfferCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([productId])
  @@index([status])
  @@index([highlight])
  @@index([startsAt, endsAt])
}

model Coupon {
  id            String            @id @default(cuid())
  code          String            @unique
  description   String?
  type          CouponType
  value         Decimal           @db.Decimal(10, 2)
  minOrderValue Decimal?          @db.Decimal(10, 2)
  maxUses       Int?
  usesCount     Int               @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean           @default(true)
  prizes        SpinWheelPrize[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([isActive])
  @@index([startsAt, endsAt])
}

model Lead {
  id        String     @id @default(cuid())
  name      String?
  phone     String
  email     String?
  source    String
  status    LeadStatus @default(NEW)
  notes     String?
  consent   Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([phone])
  @@index([status])
  @@index([source])
}

model Customer {
  id                String              @id @default(cuid())
  name              String
  phone             String?             @unique
  email             String?             @unique
  document          String?             @unique
  birthDate         DateTime?
  address           String?
  city              String              @default("Ivate")
  neighborhood      String?
  notes             String?
  imageUrl          String?
  googleSubject     String?             @unique
  lastLoginAt       DateTime?
  status            CustomerStatus      @default(ACTIVE)
  spinWheelAttempts SpinWheelAttempt[]
  cashbackAccount   CashbackAccount?
  whatsappContacts  WhatsAppContact[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status])
  @@index([city])
  @@index([lastLoginAt])
}

model SpinWheelCampaign {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  description          String?
  startsAt             DateTime?
  endsAt               DateTime?
  isActive             Boolean            @default(false)
  dailyLimitPerPhone   Int                @default(1)
  maxAttemptsPerCustomer Int              @default(1)
  prizes               SpinWheelPrize[]
  attempts             SpinWheelAttempt[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([isActive])
  @@index([startsAt, endsAt])
}

model SpinWheelPrize {
  id          String             @id @default(cuid())
  campaignId  String
  campaign    SpinWheelCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  couponId    String?
  coupon      Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  label       String
  description String?
  probability Decimal            @db.Decimal(5, 2)
  maxWins     Int?
  winsCount   Int                @default(0)
  isActive    Boolean            @default(true)
  sortOrder   Int                @default(0)
  attempts    SpinWheelAttempt[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([campaignId])
  @@index([couponId])
  @@index([isActive])
  @@unique([campaignId, label])
}

model SpinWheelAttempt {
  id          String                 @id @default(cuid())
  campaignId  String
  campaign    SpinWheelCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prizeId     String?
  prize       SpinWheelPrize?        @relation(fields: [prizeId], references: [id], onDelete: SetNull)
  customerId  String?
  customer    Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  phone       String
  ipAddress   String?
  userAgent   String?
  status      SpinWheelAttemptStatus @default(LOST)
  createdAt   DateTime               @default(now())

  @@index([campaignId])
  @@index([prizeId])
  @@index([customerId])
  @@index([phone, createdAt])
}

model CashbackAccount {
  id               String                @id @default(cuid())
  customerId       String                @unique
  customer         Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  balance          Decimal               @default(0) @db.Decimal(10, 2)
  lifetimeEarned   Decimal               @default(0) @db.Decimal(10, 2)
  lifetimeRedeemed Decimal               @default(0) @db.Decimal(10, 2)
  transactions     CashbackTransaction[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model CashbackTransaction {
  id          String                  @id @default(cuid())
  accountId   String
  account     CashbackAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        CashbackTransactionType
  amount      Decimal                 @db.Decimal(10, 2)
  description String
  reference   String?
  expiresAt   DateTime?
  createdAt   DateTime                @default(now())

  @@index([accountId])
  @@index([type])
  @@index([expiresAt])
}

model WhatsAppContact {
  id                String    @id @default(cuid())
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name              String?
  phone             String
  message           String?
  source            String
  lastInteractionAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerId])
  @@index([phone])
  @@index([source])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model SecretCredential {
  id               String    @id @default(cuid())
  title            String
  service          String?
  identifier       String?
  secretCiphertext String
  secretIv         String
  secretTag        String
  notesCiphertext  String?
  notesIv          String?
  notesTag         String?
  createdById      String?
  updatedById      String?
  lastViewedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([service])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([success, createdAt])
}
